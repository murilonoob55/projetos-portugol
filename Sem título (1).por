programa {
  funcao inicio() {
    //programa semaforo
real velocidade//declarando variavel

//entrada de dados
escreva ("qual velocidade atual do carro? ")
leia(velocidade)

//estrutura concicional
se (velocidade>80){
  escreva ("MULTADO voce exedeu o limite de velocidade: 80km/h")

}senao{
  escreva("velocidade permitida. dirija com cuidado")
}
escreva("\n")//quebra uma linha
  }
}
